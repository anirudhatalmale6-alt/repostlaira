# ArialTravel Auto-Repost Configuration
# Copy this file to .env and fill in your values.

# Buffer API token (required for posting)
BUFFER_TOKEN=your_buffer_token_here

# Buffer Organization ID
BUFFER_ORG_ID=69fa0cb360a17616e3fbbe78

# Buffer Channel IDs (override defaults)
# BUFFER_TIKTOK_ID=6a0b71ce090476fb9933ea1a
# BUFFER_YOUTUBE_ID=6a02224b090476fb990b86f7
# BUFFER_INSTAGRAM_ID=6a022285090476fb990b87b9

# Enable/disable channels
# BUFFER_TIKTOK_ENABLED=true
# BUFFER_YOUTUBE_ENABLED=true
# BUFFER_INSTAGRAM_ENABLED=true

# Paths (override defaults)
# VIDEO_DIR=/opt/repostlaira/auto-repost/videos
# FORMATTED_DIR=/opt/repostlaira/auto-repost/formatted
# LOG_DIR=/opt/repostlaira/auto-repost/logs

# yt-dlp path
# YTDLP_PATH=/usr/local/bin/yt-dlp

# Scraping settings
# VIDEOS_PER_RUN=3

# Posting settings
# POST_SPACING_MINUTES=120
# FIRST_POST_IMMEDIATE=true

# Safety: default to dry-run mode (set to false for live posting)
DRY_RUN_DEFAULT=true
