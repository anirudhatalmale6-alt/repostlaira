# ArialTravel Auto-Repost Configuration
# Copy this file to .env and fill in your values.

# ─── Direct Platform APIs (PRIMARY - bypasses Buffer rate limits) ────────────

# TikTok Content Posting API
# Get access token via TikTok OAuth2 flow with your app credentials.
# Client key/secret are hardcoded but can be overridden here.
TIKTOK_ACCESS_TOKEN=
# TIKTOK_CLIENT_KEY=aw1j8mw20p6ovj1s
# TIKTOK_CLIENT_SECRET=u7emxMzPl1v0Uzct3tvukMiiNc7jaVLf

# YouTube Data API v3
# Requires Google OAuth2 credentials + refresh token.
# Set up at: https://console.cloud.google.com/apis/credentials
YOUTUBE_REFRESH_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Instagram Graph API (via Facebook)
# Requires a Facebook Page access token with instagram_content_publish permission.
# Get from: https://developers.facebook.com/tools/explorer/
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ID=

# ─── Buffer API (FALLBACK - used when direct API credentials are missing) ────

# Buffer API token (required for Buffer fallback)
BUFFER_TOKEN=your_buffer_token_here

# Buffer Organization ID
BUFFER_ORG_ID=69fa0cb360a17616e3fbbe78

# Buffer Channel IDs (override defaults)
# BUFFER_TIKTOK_ID=6a0b71ce090476fb9933ea1a
# BUFFER_YOUTUBE_ID=6a02224b090476fb990b86f7
# BUFFER_INSTAGRAM_ID=6a022285090476fb990b87b9

# Enable/disable channels
# BUFFER_TIKTOK_ENABLED=true
# BUFFER_YOUTUBE_ENABLED=true
# BUFFER_INSTAGRAM_ENABLED=true

# ─── Paths (override defaults) ──────────────────────────────────────────────

# VIDEO_DIR=/opt/repostlaira/auto-repost/videos
# FORMATTED_DIR=/opt/repostlaira/auto-repost/formatted
# LOG_DIR=/opt/repostlaira/auto-repost/logs

# yt-dlp path
# YTDLP_PATH=/usr/local/bin/yt-dlp

# ─── Scraping & Posting Settings ────────────────────────────────────────────

# VIDEOS_PER_RUN=3
# POST_SPACING_MINUTES=120
# FIRST_POST_IMMEDIATE=true

# Safety: default to dry-run mode (set to false for live posting)
DRY_RUN_DEFAULT=true
