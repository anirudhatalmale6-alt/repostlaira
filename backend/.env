# RepostLaira Backend Configuration
PORT=3010
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://repostlaira:repostlaira_secret@localhost:5432/repostlaira

# JWT
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=30d

# CORS - comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Rate limiting (requests per hour for free users)
FREE_TIER_LIMIT=10

# yt-dlp path
YTDLP_PATH=/usr/bin/yt-dlp
YTDLP_TIMEOUT=30000
